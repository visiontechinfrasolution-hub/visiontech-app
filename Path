name: Kishor AI Agent

on:
  schedule:
    - cron: '*/10 * * * *' # दर १० मिनिटांनी किशोर स्वतःहून जागे होईल
  workflow_dispatch:      # मॅन्युअली चॅट सुरू करण्यासाठी बटण

jobs:
  run-kishor:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v3

      - name: Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10' # लेटेस्ट आणि स्टेबल व्हर्जन

      - name: Install Dependencies
        run: |
          pip install --upgrade pip
          pip install requests pandas supabase google-genai

      - name: Execute Kishor Brain
        env:
          SUPABASE_URL: ${{ secrets.SUPABASE_URL }}
          SUPABASE_KEY: ${{ secrets.SUPABASE_KEY }}
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
        run: python kishor_agent.py
