def show_pdf_vintage_page():
    st.markdown("<h2 style='text-align: center;'>📜 Vintage PDF Transformer</h2>", unsafe_allow_html=True)
    st.info("Apna PDF upload karein aur use 'purana document' look dein.")
    
    uploaded_file = st.file_uploader("Upload PDF", type="pdf", key="vintage_uploader")

    if uploaded_file:
        if st.button("Generate Old Document ✨"):
            with st.spinner("Processing..."):
                try:
                    import fitz  # PyMuPDF
                    from PIL import Image, ImageEnhance, ImageFilter
                    import io
                    import numpy as np

                    doc = fitz.open(stream=uploaded_file.read(), filetype="pdf")
                    processed_images = []
                    
                    for i in range(len(doc)):
                        page = doc.load_page(i)
                        pix = page.get_pixmap(dpi=150)
                        img = Image.open(io.BytesIO(pix.tobytes())).convert("RGB")
                        
                        # Vintage Effect Logic
                        sepia = Image.new("RGB", img.size, (240, 220, 180))
                        img = Image.blend(img, sepia, alpha=0.3)
                        img = ImageEnhance.Contrast(img).enhance(1.2)
                        img = img.filter(ImageFilter.GaussianBlur(radius=0.3))
                        
                        processed_images.append(img)

                    output_pdf = io.BytesIO()
                    processed_images[0].save(output_pdf, "PDF", save_all=True, append_images=processed_images[1:])
                    
                    st.success("PDF Ready!")
                    st.download_button("📥 Download Purana PDF", data=output_pdf.getvalue(), file_name="vintage.pdf")
                except Exception as e:
                    st.error(f"Error: {e}")

