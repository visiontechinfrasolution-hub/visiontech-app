import streamlit as st
import fitz  # PyMuPDF
from PIL import Image, ImageEnhance, ImageFilter, ImageOps
import io
import random
import numpy as np

# --- Function to Apply "Old/Real Photo" Effect ---
def transform_to_vintage(pdf_file):
    doc = fitz.open(stream=pdf_file.read(), filetype="pdf")
    processed_images = []
    
    for page_num in range(len(doc)):
        page = doc.load_page(page_num)
        
        # 1. PDF Page ko High-Res image mein badlo (DPI 200 for clarity)
        pix = page.get_pixmap(dpi=200)
        img = Image.open(io.BytesIO(pix.tobytes())).convert("RGB")
        
        # 2. Random Subtle Rotation (Jaise photo kheenchi gayi ho)
        angle = random.uniform(-1.2, 1.2)
        img = img.rotate(angle, resample=Image.BICUBIC, expand=True, fillcolor=(255, 255, 255))
        
        # 3. Add Vintage Tint (Sepia/Yellowish look)
        sepia_overlay = Image.new("RGB", img.size, (240, 220, 180))
        img = Image.blend(img, sepia_overlay, alpha=0.3)
        
        # 4. Brightness aur Contrast adjust karein (Puraana dikhane ke liye)
        img = ImageEnhance.Brightness(img).enhance(0.9)
        img = ImageEnhance.Contrast(img).enhance(1.1)
        
        # 5. Add Noise/Grain (Dhool jaisa effect)
        # Hum pixels mein thoda randomness add kar rahe hain
        img_array = np.array(img)
        noise = np.random.normal(0, 15, img_array.shape).astype('uint8')
        img_array = np.clip(img_array + noise, 0, 255)
        img = Image.fromarray(img_array)

        # 6. Subtle Blur (Digital sharpness kam karne ke liye)
        img = img.filter(ImageFilter.GaussianBlur(radius=0.4))
        
        # 7. Add Vignette (Kinaro pe thoda andhera)
        # Isse aisa lagta hai ki camera se photo li gayi hai
        processed_images.append(img)
        
    # PDF Save logic
    output_pdf = io.BytesIO()
    if processed_images:
        processed_images[0].save(
            output_pdf, "PDF", save_all=True, append_images=processed_images[1:]
        )
    return output_pdf.getvalue()

# --- Streamlit UI Main App ---
def main():
    st.set_page_config(page_title="Visiontech Document Styler", layout="wide")
    
    st.title("📄 Visiontech PDF To Vintage Converter")
    st.info("Ye tool aapke digital PDF ko aisa bana dega jaise wo ek purana document ho jiski photo kheenchi gayi hai.")

    # Aapka existing dashboard content yahan ho sakta hai...
    # ...

    st.markdown("---")
    st.subheader("🛠️ Custom Effects Panel")
    
    col1, col2 = st.columns([1, 2])
    
    with col1:
        uploaded_file = st.file_uploader("Original PDF Upload karein", type="pdf", key="v_tool")
        
        if uploaded_file is not None:
            if st.button("Magic: PDF ko Purana Banayein ✨"):
                with st.spinner("Processing... Har page ko transform kiya ja raha hai."):
                    try:
                        vintage_pdf_bytes = transform_to_vintage(uploaded_file)
                        
                        st.success("Transformation Complete!")
                        st.download_button(
                            label="📥 Download Weathered PDF",
                            data=vintage_pdf_bytes,
                            file_name=f"Old_Document_{uploaded_file.name}",
                            mime="application/pdf"
                        )
                    except Exception as e:
                        st.error(f"Kuch galat hua: {e}")

    with col2:
        st.write("**Effect Details:**")
        st.write("* ✅ **Random Rotation:** Thoda tedha-medha look.")
        st.write("* ✅ **Sepia Tint:** Purane paper ka color.")
        st.write("* ✅ **Grain & Noise:** Dhool aur purani quality.")
        st.write("* ✅ **Soft Focus:** Digital sharpness ko kam kiya gaya hai.")

if __name__ == "__main__":
    main()
